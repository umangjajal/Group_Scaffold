{
  "name": "backend",
  "version": "1.0.0",
  "packageManager": "bun@1.3.9",
  "description": "Realtime Group App Backend",
  "main": "server.js",
  "scripts": {
    "gemini": "gemini",
    "start": "node dist/server.js",
    "dev": "tsx watch src/server.ts",
    "build": "tsc",
    "lint": "biome lint src",
    "format": "biome format --write src",
    "check": "biome check src",
    "test": "vitest run",
    "test:watch": "vitest",
    "check:merge-markers": "node scripts/check-merge-markers.js",
    "prestart": "bun run check:merge-markers",
    "predev": "bun run check:merge-markers"
  },
  "dependencies": {
    "@google/generative-ai": "^0.24.1",
    "@modelcontextprotocol/sdk": "^1.28.0",
    "@socket.io/redis-adapter": "^8.3.0",
    "axios": "^1.13.6",
    "bcrypt": "^6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "express-rate-limit": "^7.2.0",
    "firebase-admin": "^10.3.0",
    "helmet": "^7.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mime-types": "^3.0.2",
    "mongoose": "^7.6.0",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^8.0.4",
    "passport": "^0.7.0",
    "passport-github2": "^0.1.12",
    "passport-google-oauth20": "^2.0.0",
    "pino": "^9.1.0",
    "pino-http": "^10.1.0",
    "socket.io": "^4.7.2",
    "twilio": "^5.0.4",
    "vite": "8.0.5",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/bcrypt": "^5.0.2",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.12.7",
    "@types/nodemailer": "^6.4.14",
    "@types/passport": "^1.0.16",
    "@types/pino-http": "^5.8.4",
    "@types/supertest": "^6.0.2",
    "mongodb-memory-server": "^9.2.0",
    "nodemon": "^3.1.10",
    "pino-pretty": "^11.1.0",
    "supertest": "^7.0.0",
    "tsx": "^4.7.2",
    "typescript": "^5.4.5",
    "vitest": "^4.1.2"
  }
}
